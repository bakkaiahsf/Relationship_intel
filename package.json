{
  "name": "codex-ai-accelerator-kit",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @accelerator/web",
    "build": "npm run build --workspace @accelerator/web",
    "lint": "npm run lint --workspace @accelerator/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  }
}
